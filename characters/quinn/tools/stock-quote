#!/usr/bin/env python3
"""
Stock Quote Tool — Quinn's quick market lookup
Usage:  ./stock-quote [SYMBOL...]
        ./stock-quote                   (shows defaults)
        ./stock-quote AAPL TSLA BTC-USD

Default symbols: ^GSPC, ^DJI, ^IXIC, AAPL, TSLA, NVDA, BTC-USD
"""
import json
import sys
import urllib.request
from datetime import datetime

DEFAULT = ['%5EGSPC', '%5EDJI', '%5EIXIC', 'AAPL', 'TSLA', 'NVDA', 'BTC-USD']
NAMES = {
    '%5EGSPC': '标普500', '%5EDJI': '道琼斯', '%5EIXIC': '纳斯达克',
    'AAPL': '苹果', 'MSFT': '微软', 'GOOGL': '谷歌', 'AMZN': '亚马逊',
    'TSLA': '特斯拉', 'NVDA': '英伟达', 'META': 'Meta',
    'BTC-USD': '比特币', 'ETH-USD': '以太坊',
}

def quote(symbol):
    url = f'https://query1.finance.yahoo.com/v8/finance/chart/{symbol}?range=1d&interval=1d'
    req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
    data = json.loads(urllib.request.urlopen(req, timeout=10).read())
    r = data['chart']['result'][0]['meta']
    price = r.get('regularMarketPrice')
    prev = r.get('chartPreviousClose')
    name = NAMES.get(symbol, symbol)
    return name, price, prev

def fmt(name, price, prev):
    change = price - prev
    pct = (change / prev) * 100 if prev else 0
    dir = '📈' if change > 0 else '📉' if change < 0 else '➖'
    return f'{dir} {name:6s} {price:>10.2f}  {change:>+8.2f}  {pct:+6.2f}%'

def main():
    symbols = sys.argv[1:] if len(sys.argv) > 1 else DEFAULT
    print(f'═══ 📊 实时行情 — {datetime.now().strftime("%Y-%m-%d %H:%M")} ═══')
    print(f'{" ":11s}{"价格":>10s}  {"涨跌":>8s}  {"幅度":>7s}')
    print('─' * 45)
    for sym in symbols:
        try:
            name, price, prev = quote(sym)
            print(fmt(name, price, prev))
        except Exception as e:
            print(f'  ❌ {sym}: {e}')

if __name__ == '__main__':
    main()